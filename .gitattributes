# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.R text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.Rmd text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Data files
*.csv text eol=lf
*.tsv text eol=lf

# Binary files
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.gz binary
*.Rdata binary
*.RData binary
*.rds binary
